			"defaultValue": "adf-batch17-practice"
		},
		"ls_adls_batch17_lab_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_batch17_lab'"
		},
		"ls_source_sql_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_source_sql'"
		},
		"ls_adls_batch17_lab_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsbronzebatch17test.dfs.core.windows.net/"
		},
		"ls_source_sql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "adfbatch17dev.database.windows.net"
		},
		"ls_source_sql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "batch17dev"
		},
		"ls_source_sql_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "saparatejal9"
		}
	},
